{
  "include": [
    "src",
    "scripts",
    "tests"
  ],
  "exclude": [
    "**/__pycache__",
    ".pytest_cache",
    ".venv",
    "venv",
    "build",
    "dist"
  ],
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        "src"
      ]
    }
  ],
  "typeCheckingMode": "basic",
  "reportMissingTypeStubs": "none"
}
